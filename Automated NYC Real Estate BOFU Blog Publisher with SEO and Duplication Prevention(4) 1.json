    {
      "parameters": {
        "jsCode": "const selectedTopic = $input.item.json.selectedTopic.toLowerCase();\nconst existingBlogs = $input.item.json.existingBlogs;\n\nif (!existingBlogs || existingBlogs.length === 0) {\n  return [{ json: { selectedTopic: $input.item.json.selectedTopic, maxSimilarity: 0, similarBlog: null, reasoningScore: $input.item.json.reasoningScore } }];\n}\n\nfunction calculateSimilarity(str1, str2) {\n  const words1 = str1.toLowerCase().split(/\\s+/).filter(w => w.length > 3);\n  const words2 = str2.toLowerCase().split(/\\s+/).filter(w => w.length > 3);\n  const set1 = new Set(words1);\n  const set2 = new Set(words2);\n  const intersection = new Set([...set1].filter(x => set2.has(x)));\n  const union = new Set([...set1, ...set2]);\n  return union.size > 0 ? intersection.size / union.size : 0;\n}\n\nlet maxSimilarity = 0;\nlet similarBlog = null;\n\nfor (const blog of existingBlogs) {\n  if (blog.json.title) {\n    const similarity = calculateSimilarity(selectedTopic, blog.json.title);\n    if (similarity > maxSimilarity) {\n      maxSimilarity = similarity;\n      similarBlog = blog.json.title;\n    }\n  }\n}\n\nreturn [{ json: { selectedTopic: $input.item.json.selectedTopic, maxSimilarity, similarBlog, reasoningScore: $input.item.json.reasoningScore } }];"
      },
